                            "v3/concepts/members-vs-guests",
                            "v3/concepts/returning-users"
                        ]
                    },
                    {
                        "group": "SDK and API",
                        "pages": [
                            "v3/sdk/init",
                            "v3/sdk/vycheck",
                            "v3/sdk/vyget",
                            "v3/api/initialize",
                            "v3/api/confirmations"
                        ]
                    },
                    {
                        "group": "Advanced usage",
                        "pages": [
                            "v3/advanced/account-linking"
                        ]
                    },
                    {
                        "group": "Reference",
                        "pages": [
                            "v3/openapi"
                        ]
                    },
                    "v3/faq"
                ]
            },
            {
                "tab": "API Reference",
                "openapi": "v3/openapi.json"
            }
        ]
