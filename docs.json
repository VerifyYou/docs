{
    "$schema": "https://mintlify.com/docs.json",
    "theme": "mint",
    "name": "VerifyYou",
    "colors": {
        "primary": "#16A34A",
        "light": "#FFFFFF",
        "dark": "#000000"
    },
    "fonts": {
        "family": "Inter"
    },
    "favicon": "/favicon.svg",
    "logo": {
        "light": "/logo/light.svg",
        "dark": "/logo/dark.svg"
    },
    "navigation": {
        "tabs": [
            {
                "tab": "Docs",
                "pages": [
                    {
                        "group": "Verification processes",
                        "pages": [
                            "v3/introduction",
